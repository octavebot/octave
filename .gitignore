
!.env.example
.DS_Store
.env
.env.*
.idea/
.vscode/
# OS noise + secrets + local state — never commit
*.log
node_modules/
# Everything in src/state/ is per-environment runtime — never commit. The bot
# auto-creates anything it needs at startup. Listing individual files here was
# fragile (broker-config.json once slipped in that way). One blanket rule.
/src/state/*
/src/state/*/
# Per-strategy PDF playbooks are a runtime artifact: regenerated from the
# strategy files + backtest-stats.json on every strategy-change deploy. Like
# backtest-stats.json, they must be per-environment and NOT tracked, or the
# VPS's auto-regen would dirty the working tree and break git-sync's ff-only.
/playbooks/
